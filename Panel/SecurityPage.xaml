<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Test.Panel.SecurityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Test.Panel"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>

        <!-- Page Layout -->
        <Grid.RowDefinitions>
            <RowDefinition Height="900"/>
            <!-- Top Menu Area -->
            <RowDefinition Height="*"/>
            <!-- Content Area -->
        </Grid.RowDefinitions>

        <!-- TOP MENU CONTAINER -->
        <Grid Grid.Row="0"
              Background ="#0F0F0F"
              
              Margin="0,60,0,0">

            <!-- FIX: Define rows -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
                <RowDefinition Height="*"/>
                <!-- Frame -->
            </Grid.RowDefinitions>

            <!-- MENU BUTTONS -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="20"
                        Background="#1A1A1A"
                        CornerRadius="10"
                        Padding="70,10,70,10"
                        Grid.Row="0">
                <Border Background="#111827"
                        CornerRadius="12">

                    <Border.Shadow>
                        <ThemeShadow/>
                    </Border.Shadow>

                </Border>
                <Button x:Name="DashboardBtn"
                        CornerRadius="10"
                        Content="Dashboard"
                        Click="Dashboard_click"/>

                <Button x:Name="ProtectionBtn"
                        CornerRadius="10"
                        Content="Protection"
                        Click="Protection_click"/>

                <!--<Button x:Name="WebSecurityBtn"
                        CornerRadius="10"
                        Content="Web Security"
                        Click="WebSecurity_click"/>-->

                <!--<Button x:Name="DevicesBtn"
                        CornerRadius="10"
                        Content="Devices"
                        Click="Devices_click"/>-->

                <Button x:Name="SettingsBtn"
                        CornerRadius="10"
                        Content="Settings"
                        Click="Settings_click"/>

            </StackPanel>

            <Frame x:Name="MainFrame"
                   Grid.Row="1"
                   Margin="10"/>

        </Grid>

    </Grid>
</Page>