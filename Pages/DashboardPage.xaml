<Page
    x:Class="Test.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Test.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">

        <!-- DEFINE ROWS FIRST -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- TITLE -->
            <TextBlock
                Text="Security Overview"
                FontSize="26"
                FontWeight="SemiBold"
                VerticalAlignment="Center"
                HorizontalAlignment="Left"
                Margin="0,0,0,0"
                Foreground="White"/>

            <!-- ✅ BUTTON FIX -->
            <Button
                Content="Quick Scan"
                Grid.Column="1"
                Click="QuickScan_Click"
                HorizontalAlignment="Right"
                Padding="20,10"
                CornerRadius="10"/>

        </Grid>

        <!-- CONTENT AREA -->
        <Grid Grid.Row="1" Margin="0,20,0,100">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- STATUS CARD -->
            <Border Grid.Column="0"
                    Background="#202020"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,12,0">

                <StackPanel>
                    <TextBlock Text="Protection Status"
                               Foreground="#AAAAAA"/>

                    <!-- ✅ ADDED NAME -->
                    <TextBlock x:Name="StatusText"
                               Text="Active"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#44D62C"/>
                </StackPanel>

            </Border>

            <!-- LAST SCAN -->
            <Border Grid.Column="1"
                    Background="#202020"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,12,0">

                <StackPanel>
                    <TextBlock Text="Last Scan"
                               Foreground="#AAAAAA"/>

                    <!-- ✅ ADDED NAME -->
                    <TextBlock x:Name="LastScanText"
                               Text="Today, 10:42 AM"
                               FontSize="18"
                               Foreground="White"/>
                </StackPanel>

            </Border>

            <!-- THREATS -->
            <Border Grid.Column="2"
                    Background="#202020"
                    CornerRadius="12"
                    Padding="16">

                <StackPanel>
                    <TextBlock Text="Threats Blocked"
                               Foreground="#AAAAAA"/>

                    <!-- ✅ ALREADY CORRECT -->
                    <TextBlock x:Name="ThreatsCount"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>

            </Border>

            <!-- HISTORY SECTION -->
            <StackPanel Grid.Row="1" Margin="0,250,20,0" Spacing="10">

                <TextBlock Text="Recent Scans"
                           FontSize="14"
                           Margin="16,0,0,0"
                           FontFamily="Segoe UI Variable"
                           Foreground= "#AAAAAA"/>

                <!-- ✅ ALREADY CORRECT -->
                <ListView x:Name="HistoryList"
                          Height="200"
                          Background="Transparent">

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#202020"
                                    Padding="10"
                                    Margin="5"
                                    CornerRadius="10">

                                <StackPanel Orientation="Horizontal" Spacing="20">

                                    <TextBlock Text="{Binding ScanDate}"
                                               Foreground="#AAAAAA"/>

                                    <TextBlock Text="{Binding Result}"
                                               Foreground="White"/>

                                    <TextBlock Text="{Binding ThreatsFound}"
                                               Foreground="#44D62C"/>

                                </StackPanel>

                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>

                </ListView>

            </StackPanel>

        </Grid>

    </Grid>
</Page>