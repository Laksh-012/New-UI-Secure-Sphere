<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ========================= COLORS ========================= -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0F0F0F"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#2A2A2A"/>

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#AAAAAA"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="PrimaryAccentBrush" Color="#3A86FF"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#44D62C"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#FF4C4C"/>

    <!-- Buttons / Tabs -->
    <SolidColorBrush x:Key="TabViewButtonBackground" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="TabViewButtonForeground" Color="#FFFFFF"/>

    <!-- ========================= STYLES ========================= -->

    <!-- PAGE BACKGROUND -->
    <CornerRadius x:Key="ControlCornerRadius">10</CornerRadius>
    <Style TargetType="Page">
        <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
    </Style>

    <!-- TEXT DEFAULT -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
    </Style>

    <!-- CARD STYLE -->
    <Style TargetType="Border" x:Key="CardStyle">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- PRIMARY BUTTON -->
    <Style TargetType="Button" x:Key="PrimaryButtonStyle">
        <Setter Property="Background" Value="{StaticResource PrimaryAccentBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="20,10"/>
    </Style>

    <!-- TAB BUTTON STYLE -->
    <Style TargetType="Button" x:Key="TabButtonStyle">
        <Setter Property="Background" Value="{StaticResource TabViewButtonBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource TabViewButtonForeground}"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="16,6"/>
        <Setter Property="Margin" Value="5"/>
    </Style>

</ResourceDictionary>